extends ../layout-auth

block content
  .w-full.max-w-md.bg-white.shadow-xl.rounded-2xl.p-8

    .text-center.mb-6
      h1.text-2xl.font-bold.text-gray-800 HIS Hospital
      p.text-sm.text-gray-500 Sistema de Gestión Hospitalaria

    if error
      .mb-4.p-3.bg-red-100.text-red-700.rounded-lg.text-sm
        | #{error}

    form(method="POST", action="/login", class="space-y-5")

      .flex.flex-col
        label.text-sm.font-medium.text-gray-600(for="email") Usuario
        input#email(type="email", name="email", required
          class="mt-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none")

      .flex.flex-col
        label.text-sm.font-medium.text-gray-600(for="password") Contraseña
        input#password(type="password", name="password", required
          class="mt-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none")

      button.w-full.bg-blue-600.text-white.py-2.rounded-lg.hover:bg-blue-700.transition(type="submit")
        | Iniciar sesión

    .mt-6.text-center.text-xs.text-gray-400
      | © 2026 HIS - Hospital System