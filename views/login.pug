doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title HIS - Iniciar Sesión
    //- Importamos Tailwind CSS rápidamente por CDN
    script(src="https://cdn.tailwindcss.com")
  body.bg-blue-50.flex.items-center.justify-center.h-screen
    //- Tarjeta centralizada
    div.bg-white.p-10.rounded-2xl.shadow-xl.w-96.text-center
      //- Logo
      div.bg-blue-600.text-white.w-16.h-16.rounded-xl.flex.items-center.justify-center.text-3xl.font-bold.mx-auto.mb-6
        | H
      
      h2.text-2xl.font-bold.text-gray-900.mb-2 Bienvenido a HIS
      p.text-gray-500.text-sm.mb-8 Inicia sesión para gestionar el hospital
      
      //- Formulario que apuntará a nuestra ruta de login
      form(action="/api/auth/login" method="POST")
        div.text-left.mb-4
          label.block.text-sm.font-medium.text-gray-700.mb-1(for="username") Usuario
          input#username.w-full.border.border-gray-300.rounded-lg.px-4.py-2.focus_outline-none.focus_ring-2.focus_ring-blue-500(type="text" name="username" required placeholder="admin_general")
        
        div.text-left.mb-6
          label.block.text-sm.font-medium.text-gray-700.mb-1(for="password") Contraseña
          input#password.w-full.border.border-gray-300.rounded-lg.px-4.py-2.focus_outline-none.focus_ring-2.focus_ring-blue-500(type="password" name="password" required placeholder="••••••••")
        
        button.w-full.bg-gray-900.text-white.rounded-lg.py-3.font-semibold.hover_bg-gray-800.transition.duration-200(type="submit")
          | Ingresar al Sistema
          
      p.text-xs.text-gray-400.mt-8 HIS System v2.0 • Secure Access