doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Ingreso - HIS Pro V2.0
    script(src="https://cdn.tailwindcss.com")
  body.bg-slate-50.flex.items-center.justify-center.h-screen.font-sans.px-4
    div.w-full.max-w-md.bg-white.rounded-2xl.shadow-xl.overflow-hidden.border.border-gray-100
      //- Cabecera Azul del Login
      div.bg-blue-600.p-8.text-center
        div.w-16.h-16.bg-white.text-blue-600.rounded-2xl.flex.items-center.justify-center.text-3xl.font-extrabold.mx-auto.mb-4 H
        h1.text-3xl.font-bold.text-white HIS <span class="text-blue-200">Pro</span>
        p.text-blue-100.text-sm.mt-2 Sistema de Gestión Hospitalaria
      
      //- Formulario
      div.p-8
        h2.text-xl.font-bold.text-gray-800.mb-6 Iniciar Sesión
        
        if error
          div.bg-red-50.border-l-4.border-red-500.text-red-700.p-4.mb-6.rounded-r-lg
            p.font-bold Acceso Denegado
            p.text-sm= error
        
        form(action="/api/auth/login" method="POST" class="space-y-5")
          div
            label.block.text-sm.font-bold.text-gray-700.mb-1 Correo Electrónico
            input(type="email" name="email" class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:outline-none transition" placeholder="medico@hospital.com" required)
          
          div
            label.block.text-sm.font-bold.text-gray-700.mb-1 Contraseña
            input(type="password" name="password" class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:outline-none transition" placeholder="••••••••" required)
          
          div.flex.items-center.justify-between.text-sm.mt-2
            label.flex.items-center.text-gray-600.cursor-pointer
              input(type="checkbox" class="mr-2 rounded text-blue-600 focus:ring-blue-500")
              span Recordarme
            a(href="#" class="text-blue-600 font-bold hover:underline") ¿Olvidó su clave?
          
          button(type="submit" class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 transition shadow-md mt-4") Ingresar al Tablero
          
        div.mt-8.text-center.border-t.border-gray-100.pt-6
          p.text-xs.font-bold.text-gray-400.tracking-widest ACCESO RESTRINGIDO - V 2.0