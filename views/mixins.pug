mixin sidebarItem(icono, texto, link, activo=false)
  a(href=link class=`flex items-center gap-3 px-4 py-3 rounded-xl transition duration-200 ${activo ? 'bg-blue-50 text-blue-600 font-bold' : 'text-gray-500 hover:bg-gray-50 hover:text-gray-900'}`)
    span.text-xl= icono
    span.text-sm= texto

mixin camaCard(idCama, numero, estado, paciente=null)
  - var clickAction = estado === 'EnLimpieza' ? `marcarLimpia('${idCama}')` : `abrirPanelCama('${idCama}', '${estado}')`
  div(onclick=clickAction class=`border rounded-xl p-4 shadow-sm hover:shadow-md transition cursor-pointer ${estado === 'Libre' ? 'bg-white border-green-200' : estado === 'Ocupada' ? 'bg-blue-50 border-blue-200' : 'bg-yellow-50 border-yellow-200'}`)
    div.flex.justify-between.items-start.mb-2
      span.font-bold.text-gray-700 Cama #{numero}
      if estado === 'Libre'
        span.bg-green-100.text-green-700.text-xs.px-2.py-1.rounded-md.font-semibold Disponible
      else if estado === 'EnLimpieza'
        span.bg-yellow-100.text-yellow-700.text-xs.px-2.py-1.rounded-md.font-semibold Limpieza
      else
        span.bg-blue-100.text-blue-700.text-xs.px-2.py-1.rounded-md.font-semibold Ocupada
    if paciente
      div.mt-3.pt-3.border-t.border-blue-100
        p.text-sm.font-bold.text-gray-900 👤 #{paciente}
        p.text-xs.text-gray-500 Internado