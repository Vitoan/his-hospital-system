include mixins.pug

doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title HIS Pro V2.0
    script(src="https://cdn.tailwindcss.com")
  body.bg-slate-50.flex.h-screen.font-sans.overflow-hidden
    aside.w-64.bg-white.border-r.border-gray-200.flex.flex-col.justify-between.flex-shrink-0
      div
        div.p-6.flex.items-center.gap-3.border-b.border-gray-100
          div.bg-blue-600.text-white.w-8.h-8.rounded-lg.flex.items-center.justify-center.font-bold H
          span.font-bold.text-xl.text-gray-800 HIS <span class="text-blue-600">Pro</span>
        nav.p-4.flex.flex-col.gap-1
          if usuario.rol !== 'Paciente'
            +sidebarItem('🛏️', 'Mapa de Camas', '/dashboard')
            //- NUEVO BOTÓN AGREGADO AQUÍ:
            +sidebarItem('👥', 'Pacientes', '/pacientes')
            
          if usuario.rol === 'Recepcionista' || usuario.rol === 'Admin'
            +sidebarItem('📋', 'Admisiones y Turnos', '#')
          if usuario.rol === 'Medico' || usuario.rol === 'Enfermero' || usuario.rol === 'Admin'
            +sidebarItem('🩺', 'Pacientes Internados', '#')
          if usuario.rol === 'Paciente'
            +sidebarItem('📅', 'Mis Turnos', '#')
            +sidebarItem('📁', 'Mi Historia Clínica', '#')
          if usuario.rol === 'Admin'
            div.my-2.border-t.border-gray-100
            +sidebarItem('👥', 'Gestión de Personal', '#')
            +sidebarItem('⚙️', 'Configuración', '#')
      div.p-4.border-t.border-gray-200
        div.flex.items-center.gap-3.mb-4
          div.w-10.h-10.bg-slate-100.rounded-full.flex.items-center.justify-center.font-bold.text-slate-600 #{usuario.rol.charAt(0)}
          div
            p.text-sm.font-bold.text-gray-800= usuario.rol
            p.text-xs.text-gray-500 ID: #{usuario.id}
        form(action="/api/auth/logout" method="POST")
          button.w-full.bg-red-50.text-red-600.text-sm.font-semibold.py-2.rounded-lg.hover_bg-red-100.transition(type="submit") Cerrar Sesión
    main.flex-1.flex.flex-col.h-screen.overflow-hidden
      header.h-16.bg-white.border-b.border-gray-200.flex.items-center.justify-between.px-8.flex-shrink-0
        h2.font-semibold.text-gray-700 Tablero Operativo
        form(action="/historia-clinica" method="GET" class="relative")
            input(name="dni" class="bg-slate-100 text-sm rounded-full px-4 py-2 w-64 focus_outline-none focus_ring-2 focus_ring-blue-500" type="text" placeholder="🔍 Buscar paciente por DNI..." required)
      div.flex-1.overflow-y-auto.p-8
        block content
        div.mt-12.text-center
          p.text-xs.font-bold.text-gray-400.tracking-widest HIS SYSTEM V2.0

    div#slideOverBackdrop.fixed.inset-0.bg-gray-900.bg-opacity-50.z-40.hidden.transition-opacity(onclick="cerrarPanel()")
    div#slideOverPanel.fixed.inset-y-0.right-0.z-50.w-full.max-w-md.bg-white.shadow-2xl.transform.translate-x-full.transition-transform.duration-300.ease-in-out.flex.flex-col
      div.px-6.py-4.border-b.border-gray-200.flex.justify-between.items-center.bg-gray-50
        h2#panelTitle.text-xl.font-bold.text-gray-800 Gestión Clínica
        button.text-gray-400.text-3xl.font-bold.leading-none.hover_text-gray-600(onclick="cerrarPanel()") &times;
      div#panelContent.flex-1.overflow-y-auto.p-6
      div#panelFooter.p-6.border-t.border-gray-200.bg-gray-50

 
    script.
      
      async function marcarLimpia(idCama) {
        if(confirm("¿Confirmas que la cama está limpia y lista para un nuevo paciente?")) {
          try {
            const response = await fetch(`/api/infraestructura/cama/${idCama}/limpia`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' }
            });
            if(response.ok) { window.location.reload(); } 
            else { alert((await response.json()).error || "Error al limpiar"); }
          } catch(error) { alert("Error de conexión"); }
        }
      }

      function abrirPanelCama(idCama, estado, pacienteNombre, idEpisodio, motivo) {
        const backdrop = document.getElementById('slideOverBackdrop');
        const panel = document.getElementById('slideOverPanel');
        const title = document.getElementById('panelTitle');
        const content = document.getElementById('panelContent');
        const footer = document.getElementById('panelFooter');

        backdrop.classList.remove('hidden');
        setTimeout(() => { panel.classList.remove('translate-x-full'); }, 10);
        title.innerText = `Gestión - Cama ${idCama}`;

        if (estado === 'Libre') {
          content.innerHTML = `<div class="text-center mt-10"><div class="text-6xl mb-6">🛏️</div><h3 class="text-2xl font-bold text-gray-800">Cama Disponible</h3></div>`;
          footer.innerHTML = `<button class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 transition" onclick="mostrarFormularioInternacion('${idCama}')">+ Internar Paciente</button>`;
        } else if (estado === 'Ocupada') {
          content.innerHTML = `
            <div class="border border-blue-100 bg-blue-50 p-5 rounded-xl mb-6">
              <p class="text-xs text-blue-600 font-bold uppercase tracking-wide mb-1">Paciente Internado (Ep: #${idEpisodio})</p>
              <h3 class="text-xl font-extrabold text-gray-900 mb-2">${pacienteNombre}</h3>
              <p class="text-sm text-gray-700"><b>Motivo:</b> ${motivo}</p>
            </div>
            <div class="space-y-3">
              <button class="w-full text-left px-5 py-4 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition flex justify-between" onclick="mostrarFormularioSignos('${idEpisodio}', '${pacienteNombre}')"><span class="font-bold text-gray-700">🩺 Tomar Signos Vitales</span></button>
              <button class="w-full text-left px-5 py-4 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition flex justify-between" onclick="mostrarFormularioEvolucion('${idEpisodio}', '${pacienteNombre}')"><span class="font-bold text-gray-700">📝 Escribir Evolución Médica</span></button>
            </div>
          `;
          footer.innerHTML = `<button class="w-full bg-red-50 text-red-600 border border-red-200 font-bold py-3 rounded-xl hover:bg-red-100 transition" onclick="mostrarFormularioAlta('${idEpisodio}', '${pacienteNombre}')">Dar de Alta al Paciente</button>`;
        }
      }

       
      function mostrarFormularioInternacion(idCama) {
         
      }
      
       
      function mostrarFormularioPaciente(idPaciente, dni, nombre, apellido, telefono, obraSocial) {
        const content = document.getElementById('panelContent');
        const footer = document.getElementById('panelFooter');
        const title = document.getElementById('panelTitle');
        const backdrop = document.getElementById('slideOverBackdrop');
        const panel = document.getElementById('slideOverPanel');

        backdrop.classList.remove('hidden');
        setTimeout(() => { panel.classList.remove('translate-x-full'); }, 10);

        const esEdicion = idPaciente !== '' && idPaciente !== 'undefined';
        title.innerText = esEdicion ? "Editar Datos del Paciente" : "Registrar Nuevo Paciente";

        content.innerHTML = `
          <div class="mb-6 border-b border-gray-100 pb-4">
            <p class="text-xs text-gray-500 uppercase tracking-widest font-bold">Ficha Filiatoria</p>
          </div>
          <form id="formPaciente" onsubmit="guardarPaciente(event, '${idPaciente}')" class="space-y-4">
            <div><label class="block text-sm font-bold text-gray-700 mb-1">DNI</label><input type="text" id="PacienteDni" class="w-full border border-gray-300 rounded-lg px-3 py-2" value="${dni || ''}" required></div>
            <div class="grid grid-cols-2 gap-4">
              <div><label class="block text-sm font-bold text-gray-700 mb-1">Nombre</label><input type="text" id="PacienteNombre" class="w-full border border-gray-300 rounded-lg px-3 py-2" value="${nombre || ''}" required></div>
              <div><label class="block text-sm font-bold text-gray-700 mb-1">Apellido</label><input type="text" id="PacienteApellido" class="w-full border border-gray-300 rounded-lg px-3 py-2" value="${apellido || ''}" required></div>
            </div>
            <div><label class="block text-sm font-bold text-gray-700 mb-1">Teléfono</label><input type="text" id="PacienteTelefono" class="w-full border border-gray-300 rounded-lg px-3 py-2" value="${telefono || ''}"></div>
            <div><label class="block text-sm font-bold text-gray-700 mb-1">Obra Social</label><input type="text" id="PacienteObraSocial" class="w-full border border-gray-300 rounded-lg px-3 py-2" value="${obraSocial || ''}"></div>
            <button type="submit" class="hidden" id="btnSubmitPaciente"></button>
          </form>
        `;
        
        footer.innerHTML = `
          <div class="flex gap-3">
            <button class="w-1/3 bg-gray-200 text-gray-700 font-bold py-3 rounded-xl hover:bg-gray-300 transition" onclick="cerrarPanel()">Cancelar</button>
            <button class="w-2/3 bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 transition" onclick="document.getElementById('btnSubmitPaciente').click()">
              ${esEdicion ? 'Guardar Cambios' : 'Registrar Paciente'}
            </button>
          </div>
        `;
      }

      async function guardarPaciente(event, idPaciente) {
        event.preventDefault();
        const payload = {
          Dni: document.getElementById('PacienteDni').value,
          Nombre: document.getElementById('PacienteNombre').value,
          Apellido: document.getElementById('PacienteApellido').value,
          Telefono: document.getElementById('PacienteTelefono').value,
          ObraSocial: document.getElementById('PacienteObraSocial').value
        };

        const esEdicion = idPaciente !== '' && idPaciente !== 'undefined';
        const url = esEdicion ? `/api/pacientes/${idPaciente}` : '/api/pacientes';
        const method = esEdicion ? 'PUT' : 'POST';

        try {
          const response = await fetch(url, {
            method: method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          
          if(response.ok) {
            window.location.reload(); 
          } else {
            const data = await response.json();
            alert(data.error || 'Error al guardar los datos');
          }
        } catch(error) {
          alert('Error de conexión. ¿Está la ruta registrada en app.js?');
          console.error(error);
        }
      }
      function cerrarPanel() {
        const backdrop = document.getElementById('slideOverBackdrop');
        const panel = document.getElementById('slideOverPanel');
        panel.classList.add('translate-x-full');
        setTimeout(() => { backdrop.classList.add('hidden'); }, 300);
      }