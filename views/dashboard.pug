extends layout.pug

block content
  if usuario.rol === 'Admin'
    div.flex.justify-between.items-end.mb-6
      div
        h1.text-3xl.font-extrabold.text-gray-900 Vista General del Hospital
        p.text-gray-500.mt-1 Bienvenido, Administrador. Control total del sistema.
      button.bg-blue-600.text-white.px-5.py-2.rounded-lg.font-semibold.hover_bg-blue-700.shadow-sm.transition + Nuevo Usuario
    div.grid.grid-cols-3.gap-6.mb-8
      div.bg-white.p-6.rounded-2xl.border.border-gray-200.shadow-sm
        h3.text-gray-500.text-sm.font-bold Camas Ocupadas
        p.text-3xl.font-bold.text-blue-600 45 / 50
      div.bg-white.p-6.rounded-2xl.border.border-gray-200.shadow-sm
        h3.text-gray-500.text-sm.font-bold Pacientes en Guardia
        p.text-3xl.font-bold.text-orange-600 12
      div.bg-white.p-6.rounded-2xl.border.border-gray-200.shadow-sm
        h3.text-gray-500.text-sm.font-bold Personal Activo
        p.text-3xl.font-bold.text-green-600 8
    if mapas && mapas.length > 0
      each ala in mapas
        div.bg-white.border.border-gray-200.rounded-2xl.p-6.mb-6.shadow-sm
          h3.text-lg.font-bold.text-gray-800.mb-4 🏥 Ala: #{ala.Nombre}
          each habitacion in ala.Habitacions
            div.mb-6
              h4.text-sm.font-bold.text-gray-500.uppercase.tracking-wider.mb-3 Habitación #{habitacion.Numero} (Capacidad: #{habitacion.Capacidad})
              div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4")
                each cama in habitacion.Camas
                  - var pacienteNombre = (cama.Episodios && cama.Episodios.length > 0) ? `${cama.Episodios[0].Paciente.Nombre || 'NN'} ${cama.Episodios[0].Paciente.Apellido || ''}`.trim() : null;
                  +camaCard(cama.IdCama, cama.NumeroCama, cama.Estado, pacienteNombre)
    else
      div.bg-yellow-50.border.border-yellow-200.p-6.rounded-xl.text-yellow-700
        p No hay infraestructura hospitalaria configurada.

  else if usuario.rol === 'Recepcionista' || usuario.rol === 'Medico' || usuario.rol === 'Enfermero'
    div.flex.justify-between.items-end.mb-6
      div
        h1.text-3xl.font-extrabold.text-gray-900 Mapa de Camas Interactivo
        p.text-gray-500.mt-1 Gestión en tiempo real de internaciones.
      if usuario.rol === 'Recepcionista'
        button.bg-green-600.text-white.px-5.py-2.rounded-lg.font-semibold.hover_bg-green-700.shadow-sm.transition + Nueva Admisión
    if mapas && mapas.length > 0
      each ala in mapas
        div.bg-white.border.border-gray-200.rounded-2xl.p-6.mb-6.shadow-sm
          h3.text-lg.font-bold.text-gray-800.mb-4 🏥 Ala: #{ala.Nombre}
          each habitacion in ala.Habitacions
            div.mb-6
              h4.text-sm.font-bold.text-gray-500.uppercase.tracking-wider.mb-3 Habitación #{habitacion.Numero} (Capacidad: #{habitacion.Capacidad})
              div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4")
                each cama in habitacion.Camas
                  - var pacienteNombre = (cama.Episodios && cama.Episodios.length > 0) ? `${cama.Episodios[0].Paciente.Nombre || 'NN'} ${cama.Episodios[0].Paciente.Apellido || ''}`.trim() : null;
                  +camaCard(cama.IdCama, cama.NumeroCama, cama.Estado, pacienteNombre)
    else
      div.bg-yellow-50.border.border-yellow-200.p-6.rounded-xl.text-yellow-700
        p No hay infraestructura hospitalaria configurada.

  else if usuario.rol === 'Paciente'
    div.flex.justify-between.items-end.mb-6
      div
        h1.text-3xl.font-extrabold.text-gray-900 Portal del Paciente
        p.text-gray-500.mt-1 Hola. Aquí puedes gestionar tu salud.
      button.bg-blue-600.text-white.px-5.py-2.rounded-lg.font-semibold.hover_bg-blue-700.shadow-sm.transition + Solicitar Turno
    div.bg-white.border.border-gray-200.rounded-2xl.p-6.mb-6.shadow-sm
      h3.text-lg.font-bold.text-gray-800.mb-4 📅 Tus Próximos Turnos
      div.border.border-gray-100.rounded-xl.p-4.flex.justify-between.items-center
        div
          p.font-bold.text-gray-900 Dr. Gregory House (Clínica Médica)
          p.text-sm.text-gray-500 Jueves 26 de Febrero - 10:00 AM
        button.text-red-500.font-bold.text-sm Cancelar