extends layout.pug

block content
  div.flex.justify-between.items-end.mb-6
    div
      h1.text-3xl.font-extrabold.text-gray-900 Historia Clínica Unificada
      p.text-gray-500.mt-1 Búsqueda y registro del historial del paciente.
    a(href="/dashboard" class="text-blue-600 font-bold hover_underline") ← Volver al Mapa

  if paciente
    //- TARJETA PRINCIPAL DEL PACIENTE
    div.bg-white.border.border-gray-200.rounded-2xl.p-6.mb-8.shadow-sm.flex.items-center.gap-6
      div.w-16.h-16.bg-blue-100.text-blue-600.rounded-full.flex.items-center.justify-center.text-3xl.font-bold #{paciente.Nombre.charAt(0)}
      div
        h2.text-2xl.font-bold.text-gray-900 #{paciente.Nombre} #{paciente.Apellido}
        div.flex.gap-4.mt-1
          p.text-sm.text-gray-500 <b>DNI:</b> #{paciente.Dni}
          p.text-sm.text-gray-500 <b>Historia N°:</b> #{paciente.IdPaciente}
          if paciente.ObraSocial
            p.text-sm.text-gray-500 <b>Cobertura:</b> #{paciente.ObraSocial}

    //- LÍNEA DE TIEMPO DE EPISODIOS
    h3.text-lg.font-bold.text-gray-800.mb-4 Historial de Episodios
    
    if paciente.Episodios && paciente.Episodios.length > 0
      div.space-y-4
        each episodio in paciente.Episodios
          div.bg-white.border.border-gray-200.rounded-xl.p-5.shadow-sm.hover_shadow-md.transition
            div.flex.justify-between.border-b.border-gray-100.pb-3.mb-3
              div
                if episodio.Estado === 'Cerrado'
                  span.bg-gray-100.text-gray-600.text-xs.px-2.py-1.rounded-md.font-bold.uppercase Cerrado
                else
                  span.bg-green-100.text-green-700.text-xs.px-2.py-1.rounded-md.font-bold.uppercase Activo
                span.text-sm.font-bold.text-gray-500.ml-3 Episodio ##{episodio.IdEpisodio}
              div.text-right
                p.text-xs.text-gray-500 Ingreso: #{new Date(episodio.FechaIngreso).toLocaleDateString()}
            
            h4.text-lg.font-bold.text-gray-800 Motivo: #{episodio.MotivoInternacion || 'No especificado'}
            
            div.mt-4.flex.gap-3
              button.text-blue-600.font-bold.text-sm.bg-blue-50.px-3.py-2.rounded-lg.hover_bg-blue-100 Ver Evoluciones
              button.text-gray-600.font-bold.text-sm.bg-gray-50.px-3.py-2.rounded-lg.hover_bg-gray-200 Signos Vitales
    else
      div.bg-yellow-50.border.border-yellow-200.p-6.rounded-xl.text-yellow-700.text-center
        p.font-bold Este paciente no tiene internaciones previas en el sistema.

  else if busqueda
    div.bg-red-50.border.border-red-200.p-6.rounded-xl.text-red-600.text-center
      p.font-bold No se encontró ningún paciente con el DNI "#{busqueda}".
      button.mt-3.bg-red-600.text-white.px-4.py-2.rounded-lg.font-bold + Registrar Nuevo Paciente

  else
    div.text-center.py-16
      div.text-6xl.mb-4 🔍
      h3.text-xl.font-bold.text-gray-700 Busca un paciente
      p.text-gray-500 Ingresa el DNI en la barra de búsqueda superior para cargar su historial clínico.